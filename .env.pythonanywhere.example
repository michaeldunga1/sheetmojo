# Copy to .env on PythonAnywhere and fill with real values.
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,::1,pythonanywhere.com,.pythonanywhere.com,username.pythonanywhere.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://*.pythonanywhere.com,https://username.pythonanywhere.com
DJANGO_SECURE_SSL_REDIRECT=True
